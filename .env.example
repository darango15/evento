# Configuración de la Aplicación EventoSaaS
# Copia este archivo como .env y ajusta los valores

# ─────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────
APP_NAME="EventoSaaS"
APP_ENV=development
# development | production
APP_DEBUG=true
APP_URL=http://evento.test
APP_KEY=cambia_esto_por_una_clave_aleatoria_de_32_caracteres

# Dominio base para resolver tenants por subdominio
# En XAMPP local: evento.test
# Los tenants acceden como: demo.evento.test
TENANT_BASE_DOMAIN=evento.test

# ─────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=evento_saas
DB_USER=root
DB_PASS=

# ─────────────────────────────────────────────
# SESIONES
# ─────────────────────────────────────────────
SESSION_NAME=evento_session
SESSION_LIFETIME=7200
# Segundos (2 horas)

# ─────────────────────────────────────────────
# CORREO ELECTRÓNICO
# ─────────────────────────────────────────────
MAIL_DRIVER=smtp
# smtp | sendmail | log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@evento.test
MAIL_FROM_NAME="EventoSaaS"

# ─────────────────────────────────────────────
# ARCHIVOS Y UPLOADS
# ─────────────────────────────────────────────
UPLOAD_MAX_SIZE=5242880
# Bytes (5 MB)
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf

# ─────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────
LOG_LEVEL=debug
# debug | info | warning | error
LOG_FILE=logs/app.log

# ─────────────────────────────────────────────
# TIMEZONE
# ─────────────────────────────────────────────
APP_TIMEZONE=America/Mexico_City

# ─────────────────────────────────────────────
# CORS (orígenes permitidos separados por coma)
# En producción especifica el dominio exacto de la PWA
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://evento.test

# ─────────────────────────────────────────────
# SERVICIO QR EXTERNO
# ─────────────────────────────────────────────
QR_API_URL=https://qr.innovate.com.pa/api/v1/qr/generate
QR_API_KEY=vuBQ-HnEgXmtEKJ2Njg-f6OVxSo__TZksGNjoUYmZnM
