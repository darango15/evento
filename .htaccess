Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso directo a directorios internos
    RewriteRule ^(app|views|database|logs|vendor)(/.*)?$ - [F,L]

    # Redirigir todo a public/ manteniendo la URL
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# Bloquear acceso directo a archivos sensibles
<FilesMatch "\.(env|sql|log|lock|md|gitignore)$">
    Require all denied
</FilesMatch>
