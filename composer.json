{
    "name": "eventosaas/core",
    "description": "Sistema multi-tenant SaaS de gestión de eventos",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "phpqrcode/phpqrcode": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8000 -t public/",
        "install-app": "php public/install.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
